<% if @pagy.pages > 1 %>
  <nav class="mt-8 flex items-center justify-center gap-2 text-sm">
    <% if @pagy.prev %>
      <%= link_to "← Prev", url_for(request.query_parameters.merge(page: @pagy.prev)),
            class: "rounded-lg border border-slate-300 bg-white px-3 py-1.5 hover:bg-slate-50" %>
    <% else %>
      <span class="rounded-lg border border-slate-200 px-3 py-1.5 text-slate-300">← Prev</span>
    <% end %>

    <span class="px-2 text-slate-500">Page <%= @pagy.page %> of <%= @pagy.pages %></span>

    <% if @pagy.next %>
      <%= link_to "Next →", url_for(request.query_parameters.merge(page: @pagy.next)),
            class: "rounded-lg border border-slate-300 bg-white px-3 py-1.5 hover:bg-slate-50" %>
    <% else %>
      <span class="rounded-lg border border-slate-200 px-3 py-1.5 text-slate-300">Next →</span>
    <% end %>
  </nav>
<% end %>
