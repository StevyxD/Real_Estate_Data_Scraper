<% content_for :title, "Property registrations · RERA Easy" %>

<%= form_with url: documents_path, method: :get do |f| %>
  <%# Keep the chosen project number when only sort/search changes (cleared if the
      village dropdown is switched — handled in the controller). %>
  <%= hidden_field_tag :property_id, @property&.id if @property %>
  <div class="flex flex-col gap-3 rounded-xl border border-slate-200 bg-white p-4 shadow-sm sm:flex-row sm:items-end">
    <div class="flex-1">
      <label class="mb-1 block text-xs font-medium text-slate-500">Search</label>
      <%= f.search_field :q, value: @query, placeholder: "Building, seller, buyer, doc no…",
            class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-indigo-500" %>
    </div>
    <div>
      <label class="mb-1 block text-xs font-medium text-slate-500">Village</label>
      <%= f.select :village,
            options_for_select([["All villages", ""]] + @villages.map { |v| [v, v] }, @village),
            {}, class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-indigo-500 sm:w-44" %>
    </div>
    <div>
      <label class="mb-1 block text-xs font-medium text-slate-500">Sort</label>
      <%= f.select :sort, options_for_select(sort_options, @sort),
            {}, class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-indigo-500 sm:w-44" %>
    </div>
    <%= f.submit "Apply", class: "cursor-pointer rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700" %>
  </div>
<% end %>

<% if @village.present? && @properties.any? %>
  <% chip = ->(active) { "rounded-full border px-3 py-1 text-xs font-medium #{active ? 'border-indigo-600 bg-indigo-600 text-white' : 'border-slate-300 bg-white text-slate-600 hover:border-indigo-400'}" } %>
  <% arrow = "flex h-7 w-7 items-center justify-center rounded-full border border-slate-300 bg-white text-slate-600 hover:border-indigo-400" %>
  <div class="mt-4 rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
    <div class="mb-3 flex flex-wrap items-center justify-between gap-2">
      <p class="text-xs font-medium text-slate-500">
        Project numbers in <span class="font-semibold text-slate-700"><%= @village %></span>
        <span class="text-slate-400">· <%= @properties.size %> with documents</span>
      </p>
      <% if @property_groups.size > 1 %>
        <label class="flex items-center gap-2 text-xs text-slate-500">
          Jump to
          <select data-controller="select-navigate" data-action="change->select-navigate#go"
                  class="rounded-lg border border-slate-300 px-2 py-1 text-xs focus:border-indigo-500 focus:ring-indigo-500">
            <% @property_groups.each do |from| %>
              <%= tag.option "#{from}–#{from + 9}",
                    value: documents_path(village: @village, num_from: from, property_id: @property&.id, q: @query.presence, sort: @sort),
                    selected: from == @num_from %>
            <% end %>
          </select>
        </label>
      <% end %>
    </div>

    <div class="flex flex-wrap items-center gap-2">
      <%= link_to "All", documents_path(village: @village, num_from: @num_from, q: @query.presence, sort: @sort),
            class: chip.call(@property.nil?) %>

      <span class="mx-1 h-5 w-px bg-slate-200"></span>

      <% if @prev_from %>
        <%= link_to "‹", documents_path(village: @village, num_from: @prev_from, property_id: @property&.id, q: @query.presence, sort: @sort),
              class: arrow, "aria-label": "Previous group" %>
      <% else %>
        <span class="<%= arrow %> cursor-not-allowed opacity-40">‹</span>
      <% end %>

      <% @window_properties.each do |prop| %>
        <% active = @property&.id == prop.id %>
        <%= link_to documents_path(property_id: prop.id, num_from: @num_from, q: @query.presence, sort: @sort),
              class: chip.call(active) do %>
          #<%= prop.property_no %>
          <span class="<%= active ? 'text-indigo-100' : 'text-slate-400' %>">(<%= prop.docs_count %>)</span>
        <% end %>
      <% end %>

      <% if @next_from %>
        <%= link_to "›", documents_path(village: @village, num_from: @next_from, property_id: @property&.id, q: @query.presence, sort: @sort),
              class: arrow, "aria-label": "Next group" %>
      <% else %>
        <span class="<%= arrow %> cursor-not-allowed opacity-40">›</span>
      <% end %>
    </div>
  </div>
<% end %>

<div class="mt-5 flex items-baseline justify-between">
  <p class="text-sm text-slate-500">
    <% if @property %>
      <span class="font-semibold text-slate-900"><%= @property.village %> #<%= @property.property_no %> · <%= @property.year %></span> —
    <% end %>
    <span class="font-semibold text-slate-900"><%= number_with_delimiter(@pagy.count) %></span>
    registration<%= "s" unless @pagy.count == 1 %>
    <% if @total_value.to_f.positive? %>· total <span class="font-medium text-slate-700"><%= inr_short(@total_value) %></span><% end %>
  </p>
</div>

<% if @documents.any? %>
  <div class="mt-4 overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
    <div class="hidden grid-cols-12 gap-3 border-b border-slate-200 bg-slate-50 px-4 py-2 text-[11px] font-medium uppercase tracking-wide text-slate-400 sm:grid">
      <div class="col-span-4">Property</div>
      <div class="col-span-2">Type</div>
      <div class="col-span-2 text-right">Price</div>
      <div class="col-span-1">₹/sqft</div>
      <div class="col-span-1">Area</div>
      <div class="col-span-2">Registered</div>
    </div>
    <%= render partial: "row", collection: @documents, as: :document %>
  </div>
  <%= render "pagination" %>
<% else %>
  <div class="mt-20 text-center">
    <p class="text-slate-400">No registrations match your filters.</p>
    <%= link_to "Clear filters", documents_path, class: "mt-2 inline-block text-sm font-medium text-indigo-600 hover:underline" %>
  </div>
<% end %>
